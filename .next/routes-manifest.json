{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/admin/[[...index]]",
      "regex": "^/admin(?:/(.+?))?(?:/)?$",
      "routeKeys": {
        "nxtPindex": "nxtPindex"
      },
      "namedRegex": "^/admin(?:/(?<nxtPindex>.+?))?(?:/)?$"
    },
    {
      "page": "/[lang]",
      "regex": "^/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPlang": "nxtPlang"
      },
      "namedRegex": "^/(?<nxtPlang>[^/]+?)(?:/)?$"
    },
    {
      "page": "/[lang]/about",
      "regex": "^/([^/]+?)/about(?:/)?$",
      "routeKeys": {
        "nxtPlang": "nxtPlang"
      },
      "namedRegex": "^/(?<nxtPlang>[^/]+?)/about(?:/)?$"
    },
    {
      "page": "/[lang]/brands",
      "regex": "^/([^/]+?)/brands(?:/)?$",
      "routeKeys": {
        "nxtPlang": "nxtPlang"
      },
      "namedRegex": "^/(?<nxtPlang>[^/]+?)/brands(?:/)?$"
    },
    {
      "page": "/[lang]/careers",
      "regex": "^/([^/]+?)/careers(?:/)?$",
      "routeKeys": {
        "nxtPlang": "nxtPlang"
      },
      "namedRegex": "^/(?<nxtPlang>[^/]+?)/careers(?:/)?$"
    },
    {
      "page": "/[lang]/contact",
      "regex": "^/([^/]+?)/contact(?:/)?$",
      "routeKeys": {
        "nxtPlang": "nxtPlang"
      },
      "namedRegex": "^/(?<nxtPlang>[^/]+?)/contact(?:/)?$"
    },
    {
      "page": "/[lang]/franchise",
      "regex": "^/([^/]+?)/franchise(?:/)?$",
      "routeKeys": {
        "nxtPlang": "nxtPlang"
      },
      "namedRegex": "^/(?<nxtPlang>[^/]+?)/franchise(?:/)?$"
    },
    {
      "page": "/[lang]/gallery",
      "regex": "^/([^/]+?)/gallery(?:/)?$",
      "routeKeys": {
        "nxtPlang": "nxtPlang"
      },
      "namedRegex": "^/(?<nxtPlang>[^/]+?)/gallery(?:/)?$"
    },
    {
      "page": "/[lang]/ib-bor",
      "regex": "^/([^/]+?)/ib\\-bor(?:/)?$",
      "routeKeys": {
        "nxtPlang": "nxtPlang"
      },
      "namedRegex": "^/(?<nxtPlang>[^/]+?)/ib\\-bor(?:/)?$"
    },
    {
      "page": "/[lang]/kvkk",
      "regex": "^/([^/]+?)/kvkk(?:/)?$",
      "routeKeys": {
        "nxtPlang": "nxtPlang"
      },
      "namedRegex": "^/(?<nxtPlang>[^/]+?)/kvkk(?:/)?$"
    },
    {
      "page": "/[lang]/media-center",
      "regex": "^/([^/]+?)/media\\-center(?:/)?$",
      "routeKeys": {
        "nxtPlang": "nxtPlang"
      },
      "namedRegex": "^/(?<nxtPlang>[^/]+?)/media\\-center(?:/)?$"
    },
    {
      "page": "/[lang]/privacy-policy",
      "regex": "^/([^/]+?)/privacy\\-policy(?:/)?$",
      "routeKeys": {
        "nxtPlang": "nxtPlang"
      },
      "namedRegex": "^/(?<nxtPlang>[^/]+?)/privacy\\-policy(?:/)?$"
    },
    {
      "page": "/[lang]/terms-of-use",
      "regex": "^/([^/]+?)/terms\\-of\\-use(?:/)?$",
      "routeKeys": {
        "nxtPlang": "nxtPlang"
      },
      "namedRegex": "^/(?<nxtPlang>[^/]+?)/terms\\-of\\-use(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/api/careers",
      "regex": "^/api/careers(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/careers(?:/)?$"
    },
    {
      "page": "/api/franchise",
      "regex": "^/api/franchise(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/franchise(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}