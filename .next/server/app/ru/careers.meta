{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[lang]/layout,_N_T_/[lang]/careers/layout,_N_T_/[lang]/careers/page,_N_T_/ru/careers"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$lang/careers/__PAGE__",
    "/$d$lang/careers",
    "/$d$lang",
    "/_index",
    "/_head"
  ]
}