{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[lang]/layout,_N_T_/[lang]/franchise/layout,_N_T_/[lang]/franchise/page,_N_T_/az/franchise"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$lang/franchise/__PAGE__",
    "/$d$lang/franchise",
    "/$d$lang",
    "/_index",
    "/_head"
  ]
}